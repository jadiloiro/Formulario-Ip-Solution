[Unit]
Description=IP Solution - Onboarding API
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=ipsolution
WorkingDirectory=/opt/ipsolution/backend
EnvironmentFile=/opt/ipsolution/backend/.env
ExecStart=/usr/bin/node dist/main.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
